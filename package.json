{
  "name": "cakeflow-ai",
  "version": "1.0.0",
  "description": "Real-Time Smart Cake & Snacks Management System",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client-install": "npm install --prefix client",
    "client-dev": "npm run dev --prefix client",
    "client-build": "npm run build --prefix client",
    "build": "npm install --prefix client && npm run client-build",
    "postinstall": "npm install --prefix client",
    "dev-all": "concurrently \"npm run dev\" \"npm run client-dev\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.0"
  }
}
